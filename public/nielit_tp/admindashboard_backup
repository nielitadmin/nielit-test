<script>
function openTPDetails(b64) {
    try {
        const raw = atob(b64);
        const data = JSON.parse(raw);

        document.getElementById('tp_centre').textContent = data.centre_name || '-';
        document.getElementById('tp_accr').textContent = data.accreditation_no || '-';
        document.getElementById('tp_user').textContent = data.username || '-';
        document.getElementById('tp_email').textContent = data.email || '-';
        document.getElementById('tp_contact').textContent = data.contact_number || '-';
        document.getElementById('tp_location').textContent = data.location || '-';
        document.getElementById('tp_pincode').textContent = data.pincode || '-';
        document.getElementById('tp_incharge').textContent = data.incharge_name || '-';
        document.getElementById('tp_total_students').textContent = (data.tp_total_students || 0);
        document.getElementById('tp_total_paid').textContent = (parseFloat(data.tp_total_paid || 0)).toFixed(2);

        const status = data.verified || 'pending';
        if (status === 'approved') document.getElementById('tp_status').textContent = '✔ Approved';
        else if (status === 'rejected') document.getElementById('tp_status').textContent = '❌ Rejected';
        else document.getElementById('tp_status').textContent = '⏳ Pending';

        document.getElementById('tp_verified').textContent = data.verified_at || 'Not Available';

        document.getElementById('modal_tp_id').value = data.id || '';
        document.getElementById('modal_tp_id_rej').value = data.id || '';

        var modalEl = document.getElementById('tpDetailsModal');
        var bsModal = bootstrap.Modal.getOrCreateInstance(modalEl);
        bsModal.show();
    } catch (err) {
        console.error(err);
        alert('Unable to open details (data may be corrupted).');
    }
}
</script>

